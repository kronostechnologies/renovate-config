{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["local>kronostechnologies/renovate-config:base.json5"],

  packageRules: [
    {
      "allowedVersions": "<26",
      "description": "Limit Java version to <26",
      "matchDatasources": [
        "java-version"
      ],
    },
   {
      "matchCategories": ["java"],
      "description": "CodeQL support",
      "matchPackageNames": [
        "/^org\\.jetbrains\\.kotlin/"
      ],
      allowedVersions: "< 2.4.0"
    },
    {
      "matchCategories": ["js"],
      "matchDepNames": [
        "styled-components"
      ],
      allowedVersions: "< 6.0.0"
    },
    {
      "matchCategories": ["js"],
      "matchDepNames": [
        "eslint"
      ],
      allowedVersions: "< 9.0.0"
    },
    {
      "matchCategories": ["js"],
      "matchDepNames": [
        "@types/react",
        "@types/react-dom",
        "@types/react-test-renderer",
        "react",
        "react-dom",
        "react-is",
        "react-test-renderer"
      ],
      allowedVersions: "< 19.0.0"
    },
    {
      "matchCategories": ["js"],
      "matchDepNames": [
        "react-router",
        "react-router-dom"
      ],
      allowedVersions: "< 7.0.0"
    },
    {
      "matchCategories": ["php"],
      "description": "Requires psalm v7 not released yet",
      "matchDepNames": [
        "psalm/plugin-phpunit"
      ],
      allowedVersions: "< 0.20.0"
    },
    {
      "description": "v6 introduces a license change",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["gradle/actions"],
      allowedVersions: "<= 5"
    },
    {
      "matchCategories": ["java"],
      "description": "Exclude Micronaut 5",
      "matchPackageNames": [
        "/^io\\.micronaut\\.platform/"
      ],
      allowedVersions: "< 5.0.0"
    },
    {
      "matchCategories": ["java"],
      "description": "Exclude Micronaut Serizlization 3 (for micronaut 5)",
      "matchPackageNames": [
        "/^io\\.micronaut\\.serde/"
      ],
      allowedVersions: "< 3.0.0"
    }
  ]
}
